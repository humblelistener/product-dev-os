 p.big{font-size:clamp(1.15rem,2.1vw,1.7rem);line-height:1.38;max-width:30ch;margin:0 0 1rem;}\n  .em{color:var(--accent);font-style:italic;}\n  ul.pts{list-style:none;margin:1rem 0 0;padding:0;max-width:40ch;}\n  ul.pts li{font-size:clamp(1rem,1.7vw,1.35rem);line-height:1.4;margin:0 0 .9rem;padding-left:1.4rem;position:relative;}\n  ul.pts li::before{content:\"\";position:absolute;left:0;top:.6em;width:.5rem;height:.5rem;background:var(--accent-soft);border-radius:50%;}\n  ul.pts li strong{font-weight:600;}\n  .byline{font-family:\"Inter\",\"Helvetica Neue\",Arial,system-ui,sans-serif;font-size:1rem;color:var(--faint);margin-top:1.6rem;}\n  .byline strong{color:var(--ink);font-weight:600;}\n\n  /* wall number motif */\n  .wallnum{font-family:\"Inter\",sans-serif;font-size:.8rem;letter-spacing:.16em;text-transform:uppercase;color:var(--accent-soft);font-weight:700;margin-bottom:.6rem;}\n\n  /* two-column for some slides */\n  .cols{display:grid;grid-template-columns:1fr 1fr;gap:2.4rem;max-width:60ch;}\n  .card{border:1px solid var(--rule);border-top:3px solid var(--accent);border-radius:6px;padding:1.1rem 1.2rem;background:#fff;}\n  .card .ch{font-family:\"Inter\",sans-serif;font-size:.7rem;letter-spacing:.13em;text-transform:uppercase;color:var(--accent-soft);font-weight:700;}\n  .card .cn{font-weight:600;font-size:1.2rem;margin:.2rem 0 .5rem;}\n  .card p{font-size:.98rem;line-height:1.45;color:var(--soft);margin:0;}\n  @media (max-width:640px){.cols{grid-template-columns:1fr;}}\n\n  figure{margin:0;display:flex;flex-direction:column;align-items:center;}\n  figure svg{max-height:64vh;width:auto;max-width:100%;background:#fff;border:1px solid var(--line);border-radius:6px;}\n\n  blockquote{margin:0;font-size:clamp(1.5rem,3.4vw,2.7rem);line-height:1.2;font-weight:600;letter-spacing:-.012em;max-width:22ch;border:0;padding:0;}\n  blockquote .em{color:var(--accent);}\n\n  .mono-metric{font-family:\"Inter\",sans-serif;font-size:clamp(1.2rem,2.6vw,2.1rem);font-weight:600;letter-spacing:-.01em;margin:.6rem 0 1.4rem;}\n  .mono-metric .div{color:var(--accent-soft);}\n\n  /* mini plateau chart */\n  .chartwrap{margin-top:1.4rem;}\n  .chartwrap svg{width:min(560px,80vw);height:auto;}\n\n  /* nav + chrome */\n  .progress{position:fixed;top:0;left:0;height:3px;background:var(--accent);width:0;transition:width .42s ease;z-index:20;}\n  .chrome{\n    position:fixed;left:0;right:0;bottom:0;height:8vh;min-height:48px;\n    display:flex;align-items:center;justify-content:space-between;\n    padding:0 8vw;font-family:\"Inter\",sans-serif;font-size:.8rem;color:var(--faint);\n    z-index:20;pointer-events:none;\n  }\n  .chrome a,.chrome button{pointer-events:auto;}\n  .chrome .home{color:var(--faint);text-decoration:none;letter-spacing:.04em;}\n  .chrome .home:hover{color:var(--accent);}\n  .nav{display:flex;align-items:center;gap:.4rem;}\n  .nav button{\n    font-family:\"Inter\",sans-serif;border:1px solid var(--rule);background:#fff;color:var(--accent);\n    width:34px;height:34px;border-radius:6px;cursor:pointer;font-size:1rem;line-height:1;\n  }\n  .nav button:hover{background:var(--accent);color:#fff;border-color:var(--accent);}\n  .count{min-width:62px;text-align:center;font-variant-numeric:tabular-nums;}\n  .hint{position:fixed;bottom:9vh;left:0;right:0;text-align:center;font-family:\"Inter\",sans-serif;font-size:.72rem;color:var(--faint);letter-spacing:.08em;z-index:15;opacity:.9;}\n  @media (max-width:640px){.hint{display:none;}}\n</style>\n</head>\n<body>\n\n<div class=\"progress\" id=\"bar\"></div>\n<div class=\"deck\" id=\"deck\">\n\n  <!-- 1 -->\n  <section class=\"slide\">\n    <p class=\"kicker\">White Paper · A Deck</p>\n    <h1>The Product Development Operating System</h1>\n    <p class=\"lead-line\">Why AI coding tools plateau — and the structure that breaks through.</p>\n    <p class=\"byline\">By <strong>Karthik Padmanabhan</strong> · use → or click to advance</p>\n  </section>\n\n  <!-- 2 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">01</span> &nbsp;The setup</p>\n    <h2>Everyone ran the same experiment</h2>\n    <p class=\"big\">Hand developers AI assistants. Watch throughput climb. In our data, pull requests per engineer rose <span class=\"em\">more than 60%</span> in two quarters; most code now has AI in its lineage.</p>\n    <p class=\"big\">For a few months, the mood is festival.</p>\n  </section>\n\n  <!-- 3 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">02</span> &nbsp;The problem</p>\n    <h2>Then, quietly, the lights come down</h2>\n    <p class=\"lead-line\">The first cohort gets a dramatic lift. The next gets less. The organisation settles onto a higher plateau — and stops climbing. So you buy more tools. The line barely moves.</p>\n    <div class=\"chartwrap\">\n      <svg viewBox=\"0 0 560 220\" xmlns=\"http://www.w3.org/2000/svg\" aria-label=\"A curve that rises steeply then flattens into a plateau\">\n        <line x1=\"40\" y1=\"180\" x2=\"540\" y2=\"180\" stroke=\"#d8d3c8\" stroke-width=\"1.5\"/>\n        <line x1=\"40\" y1=\"180\" x2=\"40\" y2=\"20\" stroke=\"#d8d3c8\" stroke-width=\"1.5\"/>\n        <path d=\"M40,176 C120,170 150,70 240,52 C320,38 420,40 540,38\" fill=\"none\" stroke=\"#2f4858\" stroke-width=\"3\"/>\n        <path d=\"M240,52 L540,38\" fill=\"none\" stroke=\"#cf4b3a\" stroke-width=\"2\" stroke-dasharray=\"4 4\"/>\n        <circle cx=\"240\" cy=\"52\" r=\"4\" fill=\"#cf4b3a\"/>\n        <text x=\"250\" y=\"44\" font-family=\"Inter,sans-serif\" font-size=\"12\" fill=\"#cf4b3a\">the bend</text>\n        <text x=\"44\" y=\"200\" font-family=\"Inter,sans-serif\" font-size=\"11\" fill=\"#8c887f\">tools arrive</text>\n        <text x=\"470\" y=\"58\" font-family=\"Inter,sans-serif\" font-size=\"11\" fill=\"#8c887f\">plateau</text>\n      </svg>\n    </div>\n  </section>\n\n  <!-- 4 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">03</span> &nbsp;The diagnosis</p>\n    <h2>The plateau is three walls in a row</h2>\n    <p class=\"lead-line\">None of them is about model quality. The ceiling is structural — you automated the easy middle and left the hard ends untouched.</p>\n  </section>\n\n  <!-- 5 -->\n  <section class=\"slide\">\n    <p class=\"wallnum\">Wall one</p>\n    <h2>Tools speed the middle, not the ends</h2>\n    <p class=\"big\">Code generation got cheap. So the constraint moved — upstream (deciding <span class=\"em\">what</span> to build) and downstream (keeping the system healthy). A faster middle makes both ends <span class=\"em\">worse</span>.</p>\n  </section>\n\n  <!-- 6 -->\n  <section class=\"slide\">\n    <p class=\"wallnum\">Wall two</p>\n    <h2>You cannot automate vagueness</h2>\n    <p class=\"big\">My grandmother cooked for forty from \"salt as needed, cook till it's done.\" Hand that to someone who's never stood at the stove and you don't get the feast faster — you get confusion faster.</p>\n    <p class=\"big\">An agent is the new cook. It amplifies whatever process it's dropped into. The ends are where the vagueness lives.</p>\n  </section>\n\n  <!-- 7 -->\n  <section class=\"slide\">\n    <p class=\"wallnum\">Wall three</p>\n    <h2>Individual gains don't compound</h2>\n    <p class=\"big\">A tool makes <span class=\"em\">one person</span> faster. Twenty engineers 40% faster in twenty directions isn't a 40% faster org — it's twenty faster silos and a coordination problem that eats the gain.</p>\n  </section>\n\n  <!-- 8 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">04</span> &nbsp;The reframe</p>\n    <h2>An operating system, not more tools</h2>\n    <p class=\"lead-line\">A real OS <strong>schedules</strong>, <strong>allocates</strong>, <strong>enforces contracts</strong>, and <strong>abstracts the machine</strong>. And it exposes <strong>governors</strong> — tunable parameters that adapt it to context.</p>\n    <p class=\"lead-line\">Raw processors aren't a computer. Fast engineers with tools aren't an operating system.</p>\n  </section>\n\n  <!-- 9 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">05</span> &nbsp;The architecture</p>\n    <figure>\n      <svg viewBox=\"0 0 860 545\" xmlns=\"http://www.w3.org/2000/svg\" font-family=\"Inter, Helvetica Neue, Arial, sans-serif\" aria-label=\"Two planes — flow and technology — tuned by two regulators, wired by telemetry\">\n        <defs>\n          <marker id=\"ar\" markerWidth=\"9\" markerHeight=\"9\" refX=\"6\" refY=\"3\" orient=\"auto\" markerUnits=\"strokeWidth\"><path d=\"M0,0 L6,3 L0,6 Z\" fill=\"#2f4858\"/></marker>\n          <marker id=\"ars\" markerWidth=\"9\" markerHeight=\"9\" refX=\"6\" refY=\"3\" orient=\"auto\" markerUnits=\"strokeWidth\"><path d=\"M0,0 L6,3 L0,6 Z\" fill=\"#6b8a99\"/></marker>\n        </defs>\n        <text x=\"430\" y=\"18\" text-anchor=\"middle\" font-size=\"11\" fill=\"#8c887f\" font-style=\"italic\">Signals · customer · product · operations · platform</text>\n        <line x1=\"430\" y1=\"24\" x2=\"430\" y2=\"40\" stroke=\"#2f4858\" stroke-width=\"1.7\" marker-end=\"url(#ar)\"/>\n        <text x=\"250\" y=\"36\" font-size=\"10.5\" letter-spacing=\"1\" fill=\"#6b8a99\" font-weight=\"700\">FLOW PLANE</text>\n        <rect x=\"250\" y=\"44\" width=\"360\" height=\"46\" rx=\"6\" fill=\"#fff\" stroke=\"#d8d3c8\" stroke-width=\"1.2\"/>\n        <text x=\"430\" y=\"66\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" fill=\"#1b1b1a\">Organisation Knowledge agents</text>\n        <text x=\"430\" y=\"82\" text-anchor=\"middle\" font-size=\"11\" fill=\"#54524d\">maintain the org knowledge base</text>\n        <line x1=\"430\" y1=\"90\" x2=\"430\" y2=\"106\" stroke=\"#2f4858\" stroke-width=\"1.7\" marker-end=\"url(#ar)\"/>\n        <rect x=\"250\" y=\"110\" width=\"360\" height=\"92\" rx=\"6\" fill=\"#fff\" stroke=\"#d8d3c8\" stroke-width=\"1.2\"/>\n        <text x=\"430\" y=\"131\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" fill=\"#1b1b1a\">Buildable Backlog agent</text>\n        <text x=\"430\" y=\"147\" text-anchor=\"middle\" font-size=\"11\" fill=\"#54524d\">classify · manufacture clarity (rubric + escalate)</text>\n        <rect x=\"268\" y=\"158\" width=\"78\" height=\"24\" rx=\"4\" fill=\"#f7f4ee\" stroke=\"#e0dbcf\"/><text x=\"307\" y=\"174\" text-anchor=\"middle\" font-size=\"10.5\" fill=\"#1b1b1a\" font-weight=\"600\">experiment</text>\n        <rect x=\"350\" y=\"158\" width=\"78\" height=\"24\" rx=\"4\" fill=\"#f7f4ee\" stroke=\"#e0dbcf\"/><text x=\"389\" y=\"174\" text-anchor=\"middle\" font-size=\"10.5\" fill=\"#1b1b1a\" font-weight=\"600\">learning</text>\n        <rect x=\"432\" y=\"158\" width=\"78\" height=\"24\" rx=\"4\" fill=\"#f7f4ee\" stroke=\"#e0dbcf\"/><text x=\"471\" y=\"174\" text-anchor=\"middle\" font-size=\"10.5\" fill=\"#1b1b1a\" font-weight=\"600\">build</text>\n        <rect x=\"514\" y=\"158\" width=\"78\" height=\"24\" rx=\"4\" fill=\"#f7f4ee\" stroke=\"#e0dbcf\"/><text x=\"553\" y=\"174\" text-anchor=\"middle\" font-size=\"10.5\" fill=\"#1b1b1a\" font-weight=\"600\">bug</text>\n        <line x1=\"430\" y1=\"202\" x2=\"430\" y2=\"218\" stroke=\"#2f4858\" stroke-width=\"1.7\" marker-end=\"url(#ar)\"/>\n        <rect x=\"250\" y=\"222\" width=\"360\" height=\"46\" rx=\"6\" fill=\"#fff\" stroke=\"#d8d3c8\" stroke-width=\"1.2\"/>\n        <text x=\"430\" y=\"244\" text-anchor=\"middle\" font-size=\"13\" font-weight=\"700\" fill=\"#1b1b1a\">Product &amp; Platform builders</text>\n        <text x=\"430\" y=\"260\" text-anchor=\"middle\" font-size=\"11\" fill=\"#54524d\">run time-boxed missions — weeks, not quarters</text>\n        <line x1=\"430\" y1=\"268\" x2=\"430\" y2=\"284\" stroke=\"#2f4858\" stroke-width=\"1.7\" marker-end=\"url(#ar)\"/>\n        <rect x=\"40\" y=\"288\" width=\"780\" height=\"96\" rx=\"8\" fill=\"#eef2f4\" stroke=\"#6b8a99\" stroke-width=\"1.3\"/>\n        <text x=\"60\" y=\"310\" font-size=\"10.5\" letter-spacing=\"1\" fill=\"#2f4858\" font-weight=\"700\">TECHNOLOGY PLANE · one shared cloud dev environment</text>\n        <text x=\"60\" y=\"327\" font-size=\"11\" fill=\"#54524d\">humans + toil agents build here — fluid · verifiable · safe sandboxed autonomy</text>\n        <rect x=\"60\" y=\"338\" width=\"350\" height=\"36\" rx=\"5\" fill=\"#fff\" stroke=\"#d8d3c8\"/>\n        <text x=\"235\" y=\"361\" text-anchor=\"middle\" font-size=\"11\" fill=\"#1b1b1a\" font-weight=\"600\">Toil / BAU agents · scheduled · triggered</text>\n        <rect x=\"426\" y=\"338\" width=\"374\" height=\"36\" rx=\"5\" fill=\"#fff\" stroke=\"#d8d3c8\"/>\n        <circle cx=\"446\" cy=\"356\" r=\"4.5\" fill=\"#cf4b3a\"/><circle cx=\"460\" cy=\"356\" r=\"4.5\" fill=\"#e0a93b\"/><circle cx=\"474\" cy=\"356\" r=\"4.5\" fill=\"#4a9b5e\"/>\n        <text x=\"610\" y=\"360\" text-anchor=\"middle\" font-size=\"11\" fill=\"#1b1b1a\" font-weight=\"600\">code-review rubric → traffic-signal gate</text>\n        <line x1=\"430\" y1=\"384\" x2=\"430\" y2=\"400\" stroke=\"#2f4858\" stroke-width=\"1.7\" marker-end=\"url(#ar)\"/>\n        <text x=\"430\" y=\"418\" text-anchor=\"middle\" font-size=\"11\" fill=\"#8c887f\" font-style=\"italic\">→ deployed, customer-impacting change</text>\n        <rect x=\"648\" y=\"110\" width=\"178\" height=\"38\" rx=\"6\" fill=\"#2f4858\"/>\n        <text x=\"660\" y=\"128\" font-size=\"10.5\" fill=\"#fff\" font-weight=\"700\">Clarity regulator</text>\n        <text x=\"660\" y=\"141\" font-size=\"9\" fill=\"#cdd8de\">problem ↔ solution</text>\n        <line x1=\"648\" y1=\"129\" x2=\"614\" y2=\"135\" stroke=\"#2f4858\" stroke-width=\"1.5\" marker-end=\"url(#ar)\"/>\n        <rect x=\"648\" y=\"154\" width=\"178\" height=\"38\" rx=\"6\" fill=\"#2f4858\"/>\n        <text x=\"660\" y=\"172\" font-size=\"10.5\" fill=\"#fff\" font-weight=\"700\">Throughput regulator</text>\n        <text x=\"660\" y=\"185\" font-size=\"9\" fill=\"#cdd8de\">mix by classification</text>\n        <line x1=\"648\" y1=\"173\" x2=\"614\" y2=\"170\" stroke=\"#2f4858\" stroke-width=\"1.5\" marker-end=\"url(#ar)\"/>\n        <path d=\"M250,415 L44,415 L44,67 L246,67\" fill=\"none\" stroke=\"#6b8a99\" stroke-width=\"1.5\" stroke-dasharray=\"5 4\" marker-end=\"url(#ars)\"/>\n        <text x=\"30\" y=\"250\" font-size=\"10.5\" letter-spacing=\"1\" fill=\"#6b8a99\" font-weight=\"700\" transform=\"rotate(-90 30 250)\" text-anchor=\"middle\">TELEMETRY · every stage emits it</text>\n      </svg>\n    </figure>\n  </section>\n\n  <!-- 10 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">06</span> &nbsp;The flow plane</p>\n    <h2>From signal to shipped change</h2>\n    <ul class=\"pts\">\n      <li><strong>Knowledge agents</strong> — turn raw signals into a maintained org knowledge base.</li>\n      <li><strong>Buildable backlog agent</strong> — classifies work, and <em>manufactures clarity</em>: an item is buildable only when it clears a rubric; otherwise <em>escalate</em>. The honesty metric is the <strong>bounce-back rate</strong>.</li>\n      <li><strong>Builders</strong> — human and agent — run <strong>time-boxed missions</strong>.</li>\n    </ul>\n  </section>\n\n  <!-- 11 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">07</span> &nbsp;The technology plane</p>\n    <h2>One environment. Everyone builds on it.</h2>\n    <ul class=\"pts\">\n      <li>A <strong>one-click cloud dev environment</strong> for humans and toil agents alike.</li>\n      <li>You don't give an agent a privileged laptop — you give it a <strong>disposable sandbox</strong>. Safe autonomy by construction.</li>\n      <li>A <strong>code-review gate</strong> — green merges only behind independent oracles; auth/security/migrations never auto-green; autonomy <em>earned</em> against the measured false-green rate.</li>\n    </ul>\n  </section>\n\n  <!-- 12 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">08</span> &nbsp;The governors</p>\n    <h2>Two regulators — real control loops</h2>\n    <div class=\"cols\">\n      <div class=\"card\">\n        <div class=\"ch\">Regulator one</div>\n        <div class=\"cn\">Clarity</div>\n        <p>Problem ↔ solution balance. Sensor: bounce-back rate. Setpoint: your customer feedback-cycle length. The agent raises or relaxes the clarity bar from the error.</p>\n      </div>\n      <div class=\"card\">\n        <div class=\"ch\">Regulator two</div>\n        <div class=\"cn\">Throughput</div>\n        <p>Desired mix across experiment / learning / build / bug. Strategy stops being a slide and becomes an enforced allocation.</p>\n      </div>\n    </div>\n  </section>\n\n  <!-- 13 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">09</span> &nbsp;The honest part</p>\n    <h2>The constraint doesn't vanish — it moves</h2>\n    <p class=\"big\">Automate both ends and the bottleneck relocates to two coupled places: the <span class=\"em\">clarity / SME node</span>, and the <span class=\"em\">human-review queue</span> (Little's Law is not optional).</p>\n    <p class=\"big\">That's the design problem the system exists to manage: subordinate everything to it, then raise it.</p>\n  </section>\n\n  <!-- 14 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">10</span> &nbsp;The metric</p>\n    <h2>Leverage per engineer — done properly</h2>\n    <p class=\"mono-metric\">customer-impacting <span class=\"em\">outcome</span> <span class=\"div\">÷</span> humans</p>\n    <ul class=\"pts\">\n      <li>Numerator is an <strong>outcome measured after ship</strong>, not a self-declared change count.</li>\n      <li>Denominator is <strong>humans only</strong>; agents tracked separately.</li>\n      <li>Never reported alone — paired with a <strong>quality guardrail</strong> (change-failure rate).</li>\n      <li>An org-level trend, never a team target. No honest \"2×\" to promise.</li>\n    </ul>\n  </section>\n\n  <!-- 15 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">11</span> &nbsp;What's still hard</p>\n    <h2>The problems this doesn't solve</h2>\n    <ul class=\"pts\">\n      <li>Evals &amp; drift for every agent.</li>\n      <li>Model collapse on a self-ingesting knowledge base.</li>\n      <li>Prompt-injection on agents with merge rights.</li>\n      <li>The economics of supervision — the review queue is the cost centre.</li>\n      <li>Operability &amp; ownership — an operating system needs operators.</li>\n    </ul>\n  </section>\n\n  <!-- 16 -->\n  <section class=\"slide\">\n    <p class=\"kicker\"><span class=\"n\">12</span> &nbsp;Close</p>\n    <blockquote>Tools gave you a bump. The operating system is how you build a <span class=\"em\">slope</span>.</blockquote>\n    <p class=\"lead-line\" style=\"margin-top:1.6rem\">Start by measuring two numbers: your <strong>bounce-back rate</strong> and your <strong>review-queue depth</strong>. They locate your constraint before you spend a dollar on architecture.</p>\n    <p class=\"byline\">Read the white paper → <a href=\"index.html\" style=\"color:var(--accent)\">index.html</a> &nbsp;·&nbsp; the poster → <a href=\"infographic.html\" style=\"color:var(--accent)\">infographic.html</a></p>\n  </section>\n\n</div>\n\n<div class=\"chrome\">\n  <a class=\"home\" href=\"index.html\">← The Product Development Operating System</a>\n  <div class=\"nav\">\n    <button id=\"prev\" aria-label=\"Previous slide\">‹</button>\n    <span class=\"count\"><span id=\"cur\">1</span> / <span id=\"tot\">16</span></span>\n    <button id=\"next\" aria-label=\"Next slide\">›</button>\n  </div>\n</div>\n<div class=\"hint\">→ &nbsp;arrow keys, space, or click to advance</div>\n\n<script>\n  const slides=[...document.querySelectorAll('.slide')];\n  let i=0;\n  function show(n){\n    i=Math.max(0,Math.min(slides.length-1,n));\n    slides.forEach((s,k)=>s.classList.toggle('active',k===i));\n    document.getElementById('cur').textContent=i+1;\n    document.getElementById('bar').style.width=((i+1)/slides.length*100)+'%';\n    history.replaceState(null,'','#'+(i+1));\n  }\n  const next=()=>show(i+1), prev=()=>show(i-1);\n  document.addEventListener('keydown',e=>{\n    if(['ArrowRight','ArrowDown','PageDown',' '].includes(e.key)){e.preventDefault();next();}\n    else if(['ArrowLeft','ArrowUp','PageUp'].includes(e.key)){e.preventDefault();prev();}\n    else if(e.key==='Home'){show(0);} else if(e.key==='End'){show(slides.length-1);}\n  });\n  document.getElementById('next').addEventListener('click',e=>{e.stopPropagation();next();});\n  document.getElementById('prev').addEventListener('click',e=>{e.stopPropagation();prev();});\n  document.getElementById('deck').addEventListener('click',e=>{ if(e.target.closest('a,button'))return; next(); });\n  document.getElementById('tot').textContent=slides.length;\n  show((parseInt((location.hash||'').replace('#',''))||1)-1);\n</script>\n</body>\n</html>\n",
